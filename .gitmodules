[submodule "zsh_config/personal/.oh-my-zsh"]
	path = zsh_config/personal/.oh-my-zsh
	url = https://github.com/ohmyzsh/ohmyzsh.git
[submodule "zsh_config/work/.oh-my-zsh/custom/plugins/zsh-autosuggestions"]
	path = zsh_config/work/.oh-my-zsh/custom/plugins/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
[submodule "zsh_config/work/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting"]
	path = zsh_config/work/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting.git
